"""
AEVE 2.0 — fallback scene (deterministic last-resort renderable).

Generated by `renderer.healer.write_fallback_scene()` from
`pipeline/fallback_scene.py.j2` when the LLM repair loop has been exhausted.
The scene class is `Scene{{ scene_id }}` and the construct() body's
`run_time=` literals sum to within ±5% of the per-scene audio target. No
loops with `self.play()` inside — every play is unrolled so the AST runtime
predictor counts each one exactly once.

Generated for scene {{ scene_id }} (target {{ "%.3f"|format(target_runtime_s) }}s).
"""
from manim import FadeIn, FadeOut, MathTex, Scene, Text, Write

from output._style import (
    ACCENT,
    BASE_FONT_SIZE,
    FONT,
    MAIN_POS,
    PRIMARY,
    TITLE_POS,
)


class Scene{{ scene_id }}(Scene):
    def construct(self) -> None:
        title = Text(
            {{ title_repr }},
            font=FONT,
            font_size=BASE_FONT_SIZE,
            color=PRIMARY,
        ).move_to(TITLE_POS)
        self.play(FadeIn(title), run_time={{ "%.3f"|format(intro_s) }})
{% if formula_reprs %}
{% for tex in formula_reprs %}
        eq_{{ loop.index }} = MathTex({{ tex }}, color=ACCENT).move_to(MAIN_POS).shift({{ "%.3f"|format(0.6 * (loop.index0)) }} * ((-1) ** {{ loop.index0 }}))
        self.play(Write(eq_{{ loop.index }}), run_time={{ "%.3f"|format(per_formula_s) }})
{% endfor %}
        self.play(title.animate.set_color(ACCENT), run_time={{ "%.3f"|format(emphasis_s) }})
{% else %}
        self.play(title.animate.set_color(ACCENT), run_time={{ "%.3f"|format(per_formula_s) }})
        self.play(title.animate.set_color(PRIMARY), run_time={{ "%.3f"|format(emphasis_s) }})
{% endif %}
        self.play(*[FadeOut(m) for m in self.mobjects], run_time={{ "%.3f"|format(outro_s) }})
